{
  "name": "enchanter",
  "version": "0.5.0",
  "description": "MCP client with hybrid orchestrator + event-bus architecture. Integrates 10 capability plugins (trust scoring, drift detection, security veto, code review, structural fingerprinting, cost attribution, git workflow) on every outbound tool call.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "orchestrator",
    "security",
    "oauth",
    "typescript"
  ],
  "homepage": "https://github.com/enchanter-ai/enchanter#readme",
  "bugs": {
    "url": "https://github.com/enchanter-ai/enchanter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enchanter-ai/enchanter.git",
    "directory": "client/enchanter"
  },
  "license": "Apache-2.0",
  "author": "The Enchanter Authors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "enchanter": "./bin/enchanter.mjs"
  },
  "files": [
    "bin",
    "dist",
    "scripts",
    "src",
    "README.md",
    "IMPLEMENTATION_SUMMARY.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration/",
    "lint:check": "tsc --noEmit",
    "live": "tsx scripts/live.ts",
    "prepack": "npm run build",
    "stress": "tsx scripts/stress-plugins.ts",
    "red-team": "tsx scripts/red-team.ts",
    "release:dry": "tsx scripts/publish-packages.ts --dry-run",
    "release:prep": "tsx scripts/release-prep.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/sdk-node": "0.55.0",
    "node-notifier": "10.0.1",
    "undici": "7.25.0",
    "ws": "8.20.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-notifier": "^8.0.5",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "next"
  }
}